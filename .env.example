# DRiX-Brain — Environment Variables
# Copy to .env and fill in. .env is git-ignored.

# ─── REQUIRED ──────────────────────────────────────────────────────────────
# OpenRouter is the LLM provider for callLLM().
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4.5

# Postgres connection (Railway provides DATABASE_URL automatically).
DATABASE_URL=

# ─── OPTIONAL ──────────────────────────────────────────────────────────────
# Firecrawl: when set, fetchAndStrip() uses JS-rendered markdown first.
# Without it, SPAs return mostly empty content.
FIRECRAWL_API_KEY=

# Apollo: people-search for decision-maker enrichment.
APOLLO_API_KEY=

# TDE service: the upstream knowledge cache. Brain calls it to avoid re-ingesting.
TDE_BASE_URL=https://targeteddecomposition-production.up.railway.app
TDE_API_KEY=
TDE_MIN_ATOMS=15

# App URL — passed as HTTP-Referer on LLM calls.
APP_URL=http://localhost:3000
